    }

    // Tour catalog — user app reads published tours
    match /tours/{tourId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /guest_reviews/{reviewId} {
        allow read: if resource.data.approved == true || isAdmin();
        allow create: if signedIn()
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.approved == false;
        allow update, delete: if isAdmin();
      }
    }

    // Bookings — owner may update own doc (e.g. cancel); admin full access
    match /bookings/{bookingId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.user_id == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin()
        || (signedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin();
