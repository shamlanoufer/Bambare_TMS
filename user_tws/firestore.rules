      // Admin → user notifications (admin writes; user reads own inbox)
      match /notifications/{notificationId} {
        allow read: if ownsUserDoc(uid);
        allow create, delete: if isAdmin();

        // Allow the user to mark notifications as read.
        // Users may only update the `read` field (and nothing else).
        allow update: if isAdmin() || (
          ownsUserDoc(uid)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read'])
          && request.resource.data.read is bool
        );
      }
    }

